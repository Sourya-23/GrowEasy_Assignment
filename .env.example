# --- Backend (apps/api) ---
GEMINI_API_KEY=your_ai_studio_key_here
GEMINI_MODEL=gemini-2.5-flash-lite
AI_BATCH_SIZE=40
AI_MAX_CONCURRENCY=3
AI_MAX_RETRIES=5
AI_MIN_REQUEST_INTERVAL_MS=4000
MAX_FILE_SIZE_MB=5
PORT=4000

# Supabase (server-side; use the service role key on the backend only)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# --- Frontend (apps/web) ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000